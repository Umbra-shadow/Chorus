# Chorus — Track 3 · multi-agent research orchestration (analyzer → domain agents
# in parallel → coordinator synthesis → one complete document).
# Copy to .env. .env is gitignored; no key is ever committed or logged.
#
# Qwen Cloud is the MAIN brain. The key can be left blank here — a user enters
# their own Qwen key in the Chorus web UI (sent per-request as X-Qwen-Key,
# lives only in that tab, never persisted). Because the user brings their own
# key, Chorus is free to fan out many parallel agent calls per query.

# ── Qwen Cloud (OpenAI-compatible) — the brain ───────────────────────────────
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
# Reasoning-heavy: coordinator + specialists. Pin a versioned alias on judging day.
QWEN_MODEL=qwen-max
QWEN_EMBED_MODEL=text-embedding-v3

# ── Multi-agent orchestration knobs ──────────────────────────────────────────
# Hard ceiling on how many domain agents the analyzer may spin up per query.
CHORUS_MAX_AGENTS=6
# How many coordinator review rounds before it must produce the final document.
CHORUS_MAX_ROUNDS=2

# ── Web research ─────────────────────────────────────────────────────────────
# Free DuckDuckGo by default (no key). Set a Tavily key for research-grade search.
TAVILY_API_KEY=

# ── Memory substrate (Cadran) ────────────────────────────────────────────────
KIOKU_STORE=py
KIOKU_SOCKET=/tmp/chorus_kiokud.sock
KIOKU_DATA_DIR=./chorus_data

# ── Database — Chorus's OWN store, never shared with Kioku or Aria ───────────
# Paste Chorus's dedicated Neon Postgres DSN here for durable, cross-machine memory.
# Leave blank to fall back to a local SQLite file under chorus_data/.
DATABASE_URL=
CHORUS_DB=
